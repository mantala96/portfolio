# Copy to .env.local for local development WITHOUT Docker.
# When using Docker, env vars come from docker-compose.yml.

# PostgreSQL connection
DATABASE_URL=postgresql://postgres:password@localhost:5432/cms_db

# JWT signing secret — any long random string
PAYLOAD_SECRET=change-this-to-a-long-random-secret

# Runtime: CMS public URL (used for serverURL + CORS in payload.config.ts)
CMS_SERVER_URL=http://localhost:3000

# Runtime: Frontend URL allowed by CORS
CMS_WEBSITE_URL=http://localhost:5173

# Build-time: baked into Next.js bundle for Payload admin UI
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
NEXT_PUBLIC_WEBSITE_URL=http://localhost:5173
