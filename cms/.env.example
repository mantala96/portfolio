# Copy this file to .env.local for local development WITHOUT Docker.
# When using Docker, environment variables are set in docker-compose.yml.

# PostgreSQL connection string
# Docker:  postgresql://postgres:postgres@postgres:5432/cms_db
# Local:   postgresql://postgres:password@localhost:5432/cms_db
DATABASE_URL=postgresql://postgres:password@localhost:5432/cms_db

# A long, random secret string — used to sign JWTs and encrypt data
PAYLOAD_SECRET=change-this-to-a-long-random-secret

# URL where this CMS app is served
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# URL of the React website frontend (used for CORS)
NEXT_PUBLIC_WEBSITE_URL=http://localhost:5173
