# ── GitHub ─────────────────────────────────────────────────────────────────
GITHUB_USERNAME=your-github-username
IMAGE_TAG=latest

# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change-me

# ── PayloadCMS ──────────────────────────────────────────────────────────────
PAYLOAD_SECRET=change-me-long-random-string

# ── URLs (no trailing slash) ─────────────────────────────────────────────────
CMS_URL=https://cms.michalantala.cz
WEBSITE_URL=https://michalantala.cz

# ── nginx / certbot ──────────────────────────────────────────────────────────
DOMAIN=michalantala.cz
CMS_DOMAIN=cms.michalantala.cz
CERTBOT_EMAIL=your@email.com
